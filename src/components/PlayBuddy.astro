---
// A tiny, optional corner "buddy" (a coffee cup, tying into the "grab a coffee"
// line) that nudges the visitor to play a quick game of Perfect Stop. It can be
// ignored or dismissed (remembered in localStorage). Self-contained: no libs,
// canvas game, keyboard + touch, theme-aware, honors reduced-motion.
---

<div id="play-buddy" class="pb" transition:persist="play-buddy">
  <!-- Game panel -->
  <div class="pb-panel" role="dialog" aria-label="Perfect Stop — a little game">
    <div class="pb-head">
      <span class="pb-title">Perfect Stop</span>
      <button class="pb-close" type="button" aria-label="Close game">✕</button>
    </div>
    <div class="pb-stats">
      <span>streak <b class="pb-streak">0</b></span>
      <span>best <b class="pb-best">0</b></span>
    </div>
    <div class="pb-stage">
      <canvas class="pb-canvas" width="300" height="90"></canvas>
      <div class="pb-overlay" data-show>Tap to start</div>
    </div>
    <p class="pb-hint">Tap when the marker hits the zone. It shrinks each time.</p>
  </div>

  <!-- Nudge bubble -->
  <div class="pb-bubble">
    <span class="pb-bubble-text">Psst — fancy a quick game?</span>
    <button class="pb-bubble-play" type="button">play</button>
    <button class="pb-bubble-x" type="button" aria-label="Dismiss">✕</button>
  </div>

  <!-- Avatar: a little coffee cup with a face -->
  <button class="pb-avatar" type="button" aria-label="Open a little game">
    <svg viewBox="0 0 40 40" aria-hidden="true">
      <path
        class="pb-steam"
        d="M16 9 q2.5 -3 0 -6 M22 9 q2.5 -3 0 -6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"></path>
      <path
        d="M9 13 h19 v9 a7 7 0 0 1 -7 7 h-5 a7 7 0 0 1 -7 -7 z"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linejoin="round"></path>
      <path
        d="M28 16 h3.5 a3.5 3.5 0 0 1 0 7 H28"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linejoin="round"></path>
      <circle class="pb-eye" cx="15.5" cy="20" r="1.7" fill="currentColor"></circle>
      <circle class="pb-eye" cx="21.5" cy="20" r="1.7" fill="currentColor"></circle>
    </svg>
  </button>
</div>

<style>
  .pb {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 60;
  }
  @media (max-width: 520px) {
    .pb {
      right: 14px;
      bottom: 14px;
    }
  }

  /* Avatar */
  .pb-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition:
      transform 160ms var(--ease-out),
      background-color 160ms var(--ease-out),
      box-shadow 200ms var(--ease-out);
  }
  .pb-avatar svg {
    width: 27px;
    height: 27px;
    display: block;
    overflow: visible;
  }
  .pb-steam {
    opacity: 0.5;
  }
  @media (hover: hover) and (pointer: fine) {
    .pb-avatar:hover {
      background: var(--code-bg);
      box-shadow: 0 8px 26px rgba(0, 0, 0, 0.15);
    }
    .pb-avatar:hover .pb-steam {
      animation: pb-steam 1.4s var(--ease-in-out) infinite;
    }
  }
  .pb-avatar:active {
    transform: scale(0.94);
  }
  @keyframes pb-steam {
    0%, 100% { opacity: 0.25; transform: translateY(0); }
    50% { opacity: 0.7; transform: translateY(-1.5px); }
  }

  /* Nudge bubble */
  .pb-bubble {
    position: absolute;
    right: 2px;
    bottom: 60px;
    width: max-content;
    max-width: 230px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.45rem 0.55rem 0.45rem 0.75rem;
    font-size: 0.85rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform-origin: bottom right;
    opacity: 0;
    transform: translateY(6px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 200ms var(--ease-out),
      transform 200ms var(--ease-out);
  }
  .pb-bubble[data-show] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .pb-bubble-play {
    font: inherit;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.1rem 0.3rem;
    border-radius: 6px;
  }
  .pb-bubble-x {
    font: inherit;
    color: var(--fg-faint);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    padding: 0.1rem 0.3rem;
    border-radius: 6px;
  }
  @media (hover: hover) and (pointer: fine) {
    .pb-bubble-play:hover { text-decoration: underline; }
    .pb-bubble-x:hover { color: var(--fg); }
  }

  /* Panel */
  .pb-panel {
    position: absolute;
    right: 0;
    bottom: 60px;
    width: min(320px, calc(100vw - 28px));
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.18);
    padding: 0.8rem 0.95rem 0.95rem;
    transform-origin: bottom right;
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 220ms var(--ease-out),
      transform 220ms var(--ease-out);
  }
  .pb-panel[data-open] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .pb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }
  .pb-title {
    font-weight: 560;
    letter-spacing: -0.01em;
  }
  .pb-close {
    background: none;
    border: none;
    color: var(--fg-faint);
    cursor: pointer;
    font-size: 0.9rem;
    line-height: 1;
    padding: 0.15rem 0.3rem;
    border-radius: 6px;
    transition: color 160ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .pb-close:hover { color: var(--fg); }
  }
  .pb-stats {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
  }
  .pb-stats b {
    color: var(--fg);
    font-weight: 560;
    font-variant-numeric: tabular-nums;
  }
  .pb-stage {
    position: relative;
    touch-action: manipulation;
    cursor: pointer;
    border-radius: 8px;
  }
  .pb-canvas {
    display: block;
    width: 100%;
    height: 90px;
  }
  .pb-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 0.85rem;
    color: var(--fg-muted);
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms var(--ease-out);
  }
  .pb-overlay[data-show] {
    opacity: 1;
  }
  .pb-hint {
    font-size: 0.75rem;
    color: var(--fg-faint);
    margin: 0.5rem 0 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .pb-bubble,
    .pb-panel {
      transition: opacity 150ms ease;
      transform: none;
    }
    .pb-bubble[data-show],
    .pb-panel[data-open] {
      transform: none;
    }
    .pb-avatar:active {
      transform: none;
    }
    .pb-avatar:hover .pb-steam {
      animation: none;
    }
  }
</style>

<script>
  function initPlayBuddy() {
    const root = document.getElementById('play-buddy');
    if (!root || root.dataset.init) return;
    root.dataset.init = '1';

    const $ = (s: string) => root.querySelector(s) as HTMLElement;
    const avatar = $('.pb-avatar');
    const bubble = $('.pb-bubble');
    const bubblePlay = $('.pb-bubble-play');
    const bubbleX = $('.pb-bubble-x');
    const panel = $('.pb-panel');
    const closeBtn = $('.pb-close');
    const stage = $('.pb-stage');
    const canvas = $('.pb-canvas') as HTMLCanvasElement;
    const overlay = $('.pb-overlay');
    const streakEl = $('.pb-streak');
    const bestEl = $('.pb-best');
    const ctx = canvas.getContext('2d')!;

    let best = Number(localStorage.getItem('pb-best') || 0);
    bestEl.textContent = String(best);

    // ---- nudge bubble ----
    function dismissNudge() {
      delete bubble.dataset.show;
      localStorage.setItem('pb-nudge', 'off');
    }
    if (localStorage.getItem('pb-nudge') !== 'off') {
      setTimeout(() => {
        if (!root.dataset.open) bubble.dataset.show = '1';
      }, 5000);
    }
    bubbleX.addEventListener('click', (e) => {
      e.stopPropagation();
      dismissNudge();
    });

    // ---- open / close ----
    function openPanel() {
      dismissNudge();
      root.dataset.open = '1';
      panel.dataset.open = '1';
      resize();
      reset();
    }
    function closePanel() {
      delete root.dataset.open;
      delete panel.dataset.open;
      stopLoop();
    }
    avatar.addEventListener('click', () =>
      root.dataset.open ? closePanel() : openPanel()
    );
    bubblePlay.addEventListener('click', openPanel);
    closeBtn.addEventListener('click', closePanel);

    // ---- game ----
    const PAD = 16;
    let W = 300;
    const H = 90;
    let dpr = 1;
    let state: 'idle' | 'run' | 'over' = 'idle';
    let marker = 0;
    let dir = 1;
    let speed = 0.6; // fraction of track per second
    let tStart = 0.4;
    let tW = 0.22;
    let streak = 0;
    let raf = 0;
    let last = 0;
    let flashT = 0;

    function colors() {
      const cs = getComputedStyle(document.documentElement);
      return {
        fg: cs.getPropertyValue('--fg').trim() || '#111',
        track: cs.getPropertyValue('--border').trim() || '#ccc',
        accent: cs.getPropertyValue('--accent').trim() || '#3b6cf6',
      };
    }
    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth || 300;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      draw();
    }
    function newTarget() {
      tStart = Math.random() * (1 - tW);
    }
    function reset() {
      state = 'idle';
      streak = 0;
      speed = 0.6;
      tW = 0.22;
      marker = 0;
      dir = 1;
      flashT = 0;
      newTarget();
      streakEl.textContent = '0';
      overlay.textContent = 'Tap to start';
      overlay.dataset.show = '1';
      draw();
    }
    function start() {
      state = 'run';
      delete overlay.dataset.show;
      last = 0;
      stopLoop();
      raf = requestAnimationFrame(loop);
    }
    function stopLoop() {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }
    function gameOver() {
      state = 'over';
      stopLoop();
      if (streak > best) {
        best = streak;
        localStorage.setItem('pb-best', String(best));
        bestEl.textContent = String(best);
      }
      overlay.textContent = `streak ${streak} · tap to retry`;
      overlay.dataset.show = '1';
      draw();
    }
    function hit() {
      streak++;
      streakEl.textContent = String(streak);
      tW = Math.max(0.05, tW * 0.87);
      speed = Math.min(2.4, speed * 1.09);
      newTarget();
      flashT = 1;
    }
    function action() {
      if (state === 'idle') return start();
      if (state === 'over') {
        reset();
        return start();
      }
      // running
      if (marker >= tStart && marker <= tStart + tW) hit();
      else gameOver();
    }
    function loop(ts: number) {
      if (state !== 'run') {
        raf = 0;
        return;
      }
      if (!last) last = ts;
      const dt = Math.min(0.05, (ts - last) / 1000);
      last = ts;
      marker += dir * speed * dt;
      if (marker > 1) {
        marker = 1;
        dir = -1;
      } else if (marker < 0) {
        marker = 0;
        dir = 1;
      }
      if (flashT > 0) flashT = Math.max(0, flashT - dt * 3);
      draw();
      raf = requestAnimationFrame(loop);
    }
    function draw() {
      const c = colors();
      const y = H / 2;
      const x0 = PAD;
      const span = W - PAD * 2;
      ctx.clearRect(0, 0, W, H);
      // track
      ctx.lineCap = 'round';
      ctx.strokeStyle = c.track;
      ctx.lineWidth = 3;
      ctx.beginPath();
      ctx.moveTo(x0, y);
      ctx.lineTo(x0 + span, y);
      ctx.stroke();
      // target zone
      ctx.strokeStyle = c.accent;
      ctx.lineWidth = 10;
      ctx.beginPath();
      ctx.moveTo(x0 + span * tStart, y);
      ctx.lineTo(x0 + span * (tStart + tW), y);
      ctx.stroke();
      // marker
      const mx = x0 + span * marker;
      ctx.strokeStyle = c.fg;
      ctx.lineWidth = 4;
      ctx.beginPath();
      ctx.moveTo(mx, y - 17);
      ctx.lineTo(mx, y + 17);
      ctx.stroke();
      // hit flash
      if (flashT > 0) {
        ctx.globalAlpha = flashT;
        ctx.fillStyle = c.accent;
        ctx.beginPath();
        ctx.arc(mx, y, 9, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }
    }

    // ---- input ----
    stage.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      action();
    });
    document.addEventListener('keydown', (e) => {
      if (!root.dataset.open) return;
      if (e.code === 'Space' || e.code === 'Enter') {
        e.preventDefault();
        action();
      } else if (e.code === 'Escape') {
        closePanel();
      }
    });
    window.addEventListener('resize', () => {
      if (root.dataset.open) resize();
    });
    // Redraw on theme flip so canvas colors track the toggle.
    new MutationObserver(() => {
      if (root.dataset.open) draw();
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  initPlayBuddy();
  document.addEventListener('astro:page-load', initPlayBuddy);
</script>
