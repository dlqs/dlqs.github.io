---
// Email is rendered as obfuscated plain text (no mailto) to avoid scrapers.
const email = 'donaldleeqs[at]gmail.com';
---

<footer class="footer">
  <nav class="links" aria-label="Links">
    <a href="https://github.com/dlqs">GitHub</a>
    <span class="email">{email}</span>
  </nav>
  <p class="credit">
    Site design inspired by
    <a href="https://emilkowal.ski/" target="_blank" rel="noopener noreferrer"
      >Emil Kowalski</a
    >.
  </p>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }
  .links a,
  .email {
    color: var(--fg-muted);
  }
  .email {
    user-select: all;
  }
  .credit {
    margin: 1rem 0 0;
    font-size: 0.78rem;
    color: var(--fg-faint);
  }
  .credit a {
    color: var(--fg-muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 0.15em;
  }
  @media (hover: hover) and (pointer: fine) {
    .links a:hover {
      color: var(--fg);
      text-decoration: none;
    }
    .credit a:hover {
      color: var(--fg);
    }
  }
</style>
