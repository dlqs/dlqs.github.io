---
// Email is rendered as obfuscated plain text (no mailto) to avoid scrapers.
const email = 'donaldleeqs[at]gmail.com';
---

<footer class="footer">
  <nav class="links" aria-label="Links">
    <a href="https://github.com/dlqs">GitHub</a>
    <span class="email">{email}</span>
  </nav>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }
  .links a,
  .email {
    color: var(--fg-muted);
  }
  .email {
    user-select: all;
  }
  @media (hover: hover) and (pointer: fine) {
    .links a:hover {
      color: var(--fg);
      text-decoration: none;
    }
  }
</style>
